# ------------------------------------------------------------------
# Web3Forms Configuration (Contact Form Delivery)
# ------------------------------------------------------------------
# 1. Register for a free access key at https://web3forms.com
# 2. Copy this file to `.env` in the root directory.
# 3. Enter your access key below.
# 4. Restart the dev server (`npm run dev`) to load variables.

VITE_WEB3FORMS_ACCESS_KEY=your_web3forms_access_key_here
